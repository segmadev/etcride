{
    "require": {
        "vlucas/phpdotenv": "^5.6",
        "stripe/stripe-php": "^17.1",
        "phpmailer/phpmailer": "^7.0"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.9",
        "phpstan/phpstan": "^1.11",
        "phpunit/phpunit": "^9.6"
    },
    "scripts": {
        "phpcs": "phpcs api functions",
        "phpstan": "phpstan analyse api functions --level=max",
        "phpunit": "phpunit",
        "test": [
            "@phpcs",
            "@phpstan",
